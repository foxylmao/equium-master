# Copy to .env.local and customize as needed.

# RPC endpoint the miner reads + writes against. Use a Helius/Triton URL for
# production — public devnet is rate-limited.
VITE_RPC_URL=https://api.devnet.solana.com

# Cluster the explorer links should target.
VITE_CLUSTER=devnet

# Program ID. Defaults to the value baked into the IDL (current: ZKGM…6FuEQM).
# VITE_PROGRAM_ID=ZKGMUfxiRCXFPnqz9zgqAnuqJy15jk7fKbR4o6FuEQM
